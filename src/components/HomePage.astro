---
import Base from '../layouts/Base.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import Hero from './sections/Hero.astro';
import Qualities from './sections/Qualities.astro';
import Courses from './sections/Courses.astro';
import Reviews from './sections/Reviews.astro';
import Practice from './sections/Practice.astro';
import WordOfWeek from './sections/WordOfWeek.astro';
import Contact from './sections/Contact.astro';
import { getSettings, type Lang } from '../lib/content';

interface Props {
  lang: Lang;
  altUrl: string;
}
const { lang, altUrl } = Astro.props;
const s = getSettings(lang);
---

<Base lang={lang} title={`De TaalBaas — ${s.siteDescription}`} description={s.siteDescription} altUrl={altUrl}>
  <Header lang={lang} altUrl={altUrl} />
  <main>
    <Hero lang={lang} />
    <Qualities lang={lang} />
    <Courses lang={lang} />
    <Reviews lang={lang} />
    <Practice lang={lang} />
    <WordOfWeek lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
