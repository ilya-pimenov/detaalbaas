---
interface Props {
  href: string;
  class?: string;
}
const { href, class: className = '' } = Astro.props;
---

<a
  href={href}
  class={`group inline-flex items-baseline gap-1.5 font-extrabold tracking-tight ${className}`}
  aria-label="De TaalBaas"
>
  <span class="text-foreground">De</span>
  <span class="text-primary">TaalBaas</span>
</a>
