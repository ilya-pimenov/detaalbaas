---
import SectionHeading from '../SectionHeading.astro';
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import { getSettings, getCourses, pick, formatDate, type Lang } from '../../lib/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const s = getSettings(lang);
const courses = getCourses();

const labels = {
  day: pick(lang, 'Dag', 'Day'),
  start: pick(lang, 'Start', 'Start'),
  time: pick(lang, 'Tijd', 'Time'),
  hours: pick(lang, 'Uren', 'Hours'),
  price: pick(lang, 'Prijs', 'Price'),
  enroll: pick(lang, 'Inschrijven', 'Enroll'),
};
---

<section id="courses" class="py-16 md:py-24">
  <div class="container">
    <SectionHeading
      eyebrow={s.nav.courses}
      title={s.sections.coursesTitle}
      subtitle={s.sections.coursesSubtitle}
    />

    <div class="mx-auto mt-12 grid max-w-4xl gap-6 md:grid-cols-2">
      {
        courses.map((c) => {
          const rows = [
            [labels.day, pick(lang, c.day_nl, c.day_en)],
            [labels.start, formatDate(c.startDate, lang)],
            [labels.time, c.time],
            [labels.hours, pick(lang, c.hours_nl, c.hours_en)],
          ];
          return (
            <Card class="flex flex-col p-6">
              <div class="flex items-start justify-between gap-3">
                <h3 class="text-xl font-bold text-foreground">
                  {pick(lang, c.title_nl, c.title_en)}
                </h3>
                <Badge>{c.level}</Badge>
              </div>

              <dl class="mt-5 divide-y divide-border text-sm">
                {rows.map(([k, v]) => (
                  <div class="flex justify-between gap-4 py-2.5">
                    <dt class="text-muted-foreground">{k}</dt>
                    <dd class="text-right font-medium text-foreground">{v}</dd>
                  </div>
                ))}
              </dl>

              <div class="mt-5 flex items-end justify-between border-t border-border pt-5">
                <div>
                  <p class="text-xs text-muted-foreground">{labels.price}</p>
                  <p class="text-2xl font-bold text-foreground">{c.price}</p>
                </div>
                <Button href={c.enrollUrl}>{labels.enroll}</Button>
              </div>
            </Card>
          );
        })
      }
    </div>
  </div>
</section>
