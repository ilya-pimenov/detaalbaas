---
import SectionHeading from '../SectionHeading.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';
import { getSettings, pick, type Lang } from '../../lib/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const s = getSettings(lang);
const c = s.contact;
const mapsQuery = encodeURIComponent(`${c.addressLine1}, ${c.addressLine2}`);
---

<section id="contact" class="py-16 md:py-24">
  <div class="container">
    <SectionHeading eyebrow={s.nav.contact} title={c.title} subtitle={c.intro} />

    <Card class="mx-auto mt-12 max-w-4xl overflow-hidden">
      <div class="grid md:grid-cols-2">
        <div class="space-y-6 p-8 sm:p-10">
          <div class="flex items-start gap-3">
            <span class="mt-0.5 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <div>
              <p class="font-medium text-foreground">{c.addressLine1}</p>
              <p class="text-muted-foreground">{c.addressLine2}</p>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <span class="text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.391"/></svg>
            </span>
            <a class="font-medium text-foreground hover:text-primary" href={`tel:${c.phoneHref}`}>{c.phone}</a>
          </div>

          <div class="flex items-center gap-3">
            <span class="text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </span>
            <a class="font-medium text-foreground hover:text-primary" href={`mailto:${c.email}`}>{c.email}</a>
          </div>

          <div class="flex flex-col gap-3 pt-2 sm:flex-row">
            <Button href={`mailto:${c.email}`}>{c.ctaEmail}</Button>
            <Button href={`tel:${c.phoneHref}`} variant="outline">{c.ctaCall}</Button>
          </div>
        </div>

        <a
          href={`https://www.google.com/maps/search/?api=1&query=${mapsQuery}`}
          target="_blank"
          rel="noopener"
          class="group relative flex min-h-[280px] flex-col items-center justify-center gap-3 overflow-hidden bg-primary/5 p-8 text-center transition-colors hover:bg-primary/10"
          style="background-image:linear-gradient(hsl(var(--border)/0.6)_1px,transparent_1px),linear-gradient(90deg,hsl(var(--border)/0.6)_1px,transparent_1px);background-size:28px_28px;"
        >
          <span class="flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-lg shadow-primary/30 transition-transform group-hover:-translate-y-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span class="font-semibold text-foreground">{c.addressLine1}</span>
          <span class="text-sm text-muted-foreground">{c.addressLine2}</span>
          <span class="mt-1 inline-flex items-center gap-1.5 text-sm font-medium text-primary">
            {pick(lang, 'Open in Google Maps', 'Open in Google Maps')}
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </span>
        </a>
      </div>
    </Card>
  </div>
</section>
