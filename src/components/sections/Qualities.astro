---
import SectionHeading from '../SectionHeading.astro';
import Card from '../ui/Card.astro';
import { getSettings, type Lang } from '../../lib/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const s = getSettings(lang);
const q = s.qualities;

// lucide-style icons, one per quality (cycled if fewer than items)
const icons = [
  '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>', // message-circle: interactive
  '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>', // message-square: communicative
  '<path d="M11 12H3"/><path d="M16 6H3"/><path d="M16 18H3"/><path d="m18.5 9 3.5 3-3.5 3"/>', // list: task-oriented
  '<path d="m15 12-8.373 8.373a1 1 0 1 1-3-3L12 9"/><path d="m18 15 4-4"/><path d="m21.5 11.5-1.914-1.914A2 2 0 0 1 19 8.172V7l-2.26-2.26a6 6 0 0 0-4.202-1.756L9 2.96l.92.82A6.18 6.18 0 0 1 12 8.4V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"/>', // wrench: practical
  '<line x1="21" x2="3" y1="6" y2="6"/><line x1="15" x2="3" y1="12" y2="12"/><line x1="17" x2="3" y1="18" y2="18"/>', // align: structured
  '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>', // target: purposeful
  '<path d="M13 2 3 14h9l-1 8 10-12h-9z"/>', // zap: dynamic
];
---

<section class="bg-secondary/40 py-16 md:py-24">
  <div class="container">
    <SectionHeading eyebrow={q.subtitle} title={q.title} />

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        q.items.map((item, i) => (
          <Card class="p-6 transition-shadow hover:shadow-md">
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i % icons.length]} />
              </span>
              <h3 class="text-lg font-semibold text-foreground">{item.label}</h3>
            </div>
            <p class="mt-3 text-sm text-muted-foreground">{item.description}</p>
          </Card>
        ))
      }
    </div>
  </div>
</section>
